    public function tweet_search_exec(Request $request)
    {//-- 検索処理＆結果表示

        $str_kana_word = mb_convert_kana($request->search_word, "KVC");

        $str_words = $this->extractKeywords($str_kana_word,5);

        $query = VwTweetShow::query();

        foreach ($str_words as $search_word){
            $query->where('tweet_for_search', 'like', "%$search_word%");
        }
        //--検索結果のpaginateは、get送信では使えない
        $search_result = $query->orderBy('tweet_date', 'desc')->get();

        $message="";
        return view('records.tweets.search.search-result', ['message'       => $message,
                                                      'searched_word' => $request->search_word, 
                                                      'search_result' => $search_result]);
    }
    public function extractKeywords(string $input, int $limit = -1): array
    {//-- 検索文字の空白分割用関数
        $matches = [];
        preg_replace_callback(
            '/""(*SKIP)(*FAIL)|"([^"]++)"|([^"\p{Z}\p{Cc}]++)/u',
            function (array $match) use (&$matches) {
                $matches[] = $match[2] ?? $match[1];
            },
            $input,
            $limit,
            $_,
            PREG_SET_ORDER
        );
        return $matches;
    }

