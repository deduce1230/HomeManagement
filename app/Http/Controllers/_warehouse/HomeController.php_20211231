    public function index()
    {//-- トップページ --//
        return $this->get_the_day(date("Y-m-d"));
    }

    public function other_index($target_date)
    {//-- トップページ(指定日表示) --//
        return $this->get_the_day($target_date);
    }

    public function get_the_day($target_date)
    {
        //--指定日のカーボン
        $dt = new Carbon($target_date);

        //--本日以降の日付の場合は、本日に修正する
        if ($dt->isFuture()){
            $dt = Carbon::today();
        }

        //--指定日翌日のカーボン
        $dt_tmrw = $dt->copy()->subDay();
        $dt_tmrw->addDay(2);
        //--指定日前日のカーボン
        $dt_ysdy = $dt->copy()->subDay();
        $dt_ysdy->addDay(0);

        //-- 今日のご飯 --
        $cooking_show = VwCookingShow::where('meal_date',$dt)->orderBy('virtual_id', 'desc')->get();
        //-- 今日の一言 --
        //$tweet = Tweet::where('tweet_date',$target_date)->get();
        $tweet = Tweet::where('tweet_date',$dt)->get();
        //-- 今日の天気 --
        $weather_report = VwDailyReport::where('wea_date',$dt)->get();
        //-- 明日の天気 --
        $weather_report_tommorrow = VwDailyReport::where('wea_date',$dt_tmrw)->get();
        //-- 今日の予定 --
        //$calendars = VwCalendar::where([['start_date','<=',date("Y-m-d 23:59:59")],['end_date','>=',date("Y-m-d 00:00:00")]])->get();
        $calendars = VwCalendar::where([['start_date','<=',$dt->format('Y-m-d 23:59:59')],['end_date','>=',$dt->format('Y-m-d 00:00:00')]])->get();
        //-- 今日のご飯の種類 --
        $cooking_kinds = VwKindShow::where('meal_date',$dt)->get();
        if (!$cooking_kinds->isEmpty()){
            $cooking_kind = $cooking_kinds[0]->main_meal;
        } else {
            $cooking_kind = '--';
        }

        //echo $dt."<br>";
        //echo $dt_tmrw;

        $weather_name           = "XX";
        $weather_name_tommorrow = "XX";
        if (count($weather_report) > 0){
            $weather_name = $weather_report[0]->day_weather;
        }
        if (count($weather_report_tommorrow) > 0){
            $weather_name_tommorrow = $weather_report_tommorrow[0]->day_weather;
        }

        $weather_file_name           = $this->get_weather_img($weather_name);
        $weather_file_name_tommorrow = $this->get_weather_img($weather_name_tommorrow);

        return view('home', ['cooking_shows'        => $cooking_show, 'tweets' => $tweet, 
                             'weather_reports'      => $weather_report, 
                             'weather_reports_tmrw' => $weather_report_tommorrow, 
                             'file_name'            => $weather_file_name,
                             'file_name_tmrw'       => $weather_file_name_tommorrow,
                             'calendars'            => $calendars,
                             'the_day'              => $dt,
                             'the_day_after'        => $dt_tmrw,
                             'the_day_before'       => $dt_ysdy,
                             'cooking_kind'         => $cooking_kind]);
    }
    public function get_weather_img($w_name)
    {
        switch ($w_name ){
            case 'Clear':
            case 'Clear_to_Clear':
                $weather_file_name = '100.png';
                break;
            case 'Clear_to_Clouds':
                $weather_file_name = '110.png';
                break;
            case 'Clear_to_Rain':
                $weather_file_name = '112.png';
                break;
            case 'Clear_to_Snow':
                $weather_file_name = '115.png';
                break;
            case 'Clouds':
            case 'Clouds_to_Clouds':
                $weather_file_name = '200.png';
                break;
            case 'Clouds_to_Clear':
                $weather_file_name = '210.png';
                break;
            case 'Clouds_to_Rain':
                $weather_file_name = '212.png';
                break;
            case 'Clouds_to_Snow':
                $weather_file_name = '215.png';
                break;
            case 'Rain':
            case 'Rain_to_Rain':
                $weather_file_name = '300.png';
                break;
            case 'Rain_to_Clear':
                $weather_file_name = '311.png';
                break;
            case 'Rain_to_Clouds':
                $weather_file_name = '313.png';
                break;
            case 'Rain_to_Snow':
                $weather_file_name = '314.png';
                break;
            case 'Snow':
            case 'Snow_to_Snow':
                $weather_file_name = '400.png';
                break;
            case 'Snow_to_Clear':
                $weather_file_name = '411.png';
                break;
            case 'Snow_to_Clouds':
                $weather_file_name = '413.png';
                break;
            case 'Snow_to_Rain':
                $weather_file_name = '414.png';
                break;
            default:
                $weather_file_name = '999.png';
                break;
        }
        $weather_file_name = "/images/weather/" . $weather_file_name;

        return $weather_file_name;
    }

    public function weather_detail($target_date)
    {//--指定日～翌日の天気詳細表示

        //--指定日のカーボン
        $dt = new Carbon($target_date);

        //--本日以降の日付の場合は、本日に修正する
        if ($dt->isFuture()){
            $dt = Carbon::today();
        }

        //--指定日翌日のカーボン
        $dt_tmrw = $dt->copy()->subDay()->addDay();
        $dt_tmrw->addDay();


       //-- 指定日の天気(0) --
       //$weather_report0 = VwHourlyReport::whereBetween('wea_date',[date("Y/m/d",strtotime("0 day")),date("Y/m/d",strtotime("0 day"))])->orderBy('wea_date','asc')->orderBy('wea_time','asc')->get();
       $weather_report0 = VwHourlyReport::whereBetween('wea_date',[$dt->format('Y/m/d'),$dt->format('Y/m/d')])->orderBy('wea_date','asc')->orderBy('wea_time','asc')->get();
       //-- 翌日の天気(1) --
       //$weather_report1 = VwHourlyReport::whereBetween('wea_date',[date("Y/m/d",strtotime("+1 day")),date("Y/m/d",strtotime("+1 day"))])->orderBy('wea_date','asc')->orderBy('wea_time','asc')->get();
       $weather_report1 = VwHourlyReport::whereBetween('wea_date',[$dt_tmrw->format('Y/m/d'),$dt_tmrw->format('Y/m/d')])->orderBy('wea_date','asc')->orderBy('wea_time','asc')->get();

       $wea_date=array();
       $max_temp=array();
       foreach($weather_report0 as $weather_r){
           $weathers0['temperature'][]=$weather_r->temperature;
           $weathers0['humidity'][]   =$weather_r->humidity;
           $weathers0['day'][]        =$weather_r->wea_date;
           $weathers0['hour'][]       =$weather_r->wea_time;
           $weathers0['weather'][]    =$this->get_weather_img($weather_r->weather);
       }
       foreach($weather_report1 as $weather_r){
           $weathers1['temperature'][]=$weather_r->temperature;
           $weathers1['humidity'][]   =$weather_r->humidity;
           $weathers1['day'][]        =$weather_r->wea_date;
           $weathers1['hour'][]       =$weather_r->wea_time;
           $weathers1['weather'][]    =$this->get_weather_img($weather_r->weather);
       }
       //$weather_info['from'] = date("m/d",strtotime("0 day"));
       //$weather_info['to']   = date("m/d",strtotime("+1 day"));
       $weather_info['from'] = $dt->format('m/d');
       $weather_info['to']   = $dt_tmrw->format('m/d');

       //return view('weathers.today',compact('keys','counts'),['weather0' => $weathers0, 'weather1' => $weathers1, 'weather_info' => $weather_info]);
       return view('weathers.today',['weather0' => $weathers0, 'weather1' => $weathers1, 'weather_info' => $weather_info]);
    }

