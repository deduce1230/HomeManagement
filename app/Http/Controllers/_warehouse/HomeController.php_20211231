    public function tweet_update(TweetRequest $request)
    {//-- 一言日記更新処理
        //
        $targetRecId = $request->rec_id;;
        $tweet_savedata = [
            'rec_id'      => $targetRecId,
            'tweet_date'  => $request->tweet_date,
            'tweet'       => $request->tweet,
            'ref_url'     => $request->ref_url,
            'rep_user_id' => Auth::id(),
        ];

        $record = Tweet::where('rec_id', $targetRecId)->update($tweet_savedata);

        // 画像保存
        //if (!is_null($request->imagedata)){
        if (strlen($request->imagedata) > 3000){//何もcanvasになくてもちょっと送られてくるみたいなので・・・
            $image = $request->imagedata;  // your base64 encoded
            $image = str_replace('data:image/jpeg;base64,', '', $image);
            $image = str_replace('data:image/png;base64,', '', $image);
            $image = str_replace(' ', '+', $image);

            $imageName = 'diary'.$targetRecId.'.jpg';
            \File::put(public_path(). '/photos/diary/' . $imageName, base64_decode($image));
        }

        return redirect('/')->with('poststatus', '更新しました');

    }

    public function tweet_delete($rec_id)
    {//-- 一言日記削除処理

        $record = Tweet::findOrFail($rec_id);

        $record->delete();

        //-- 写真がある場合、削除 --
        $targetFile = '/opt/home-management/www/public/photos/diary/diary'.$rec_id.'.jpg';
        if (file_exists($targetFile)){
            unlink($targetFile);
        }

        return redirect('/')->with('poststatus', 'データ(記録のみ)を削除しました');
    }

