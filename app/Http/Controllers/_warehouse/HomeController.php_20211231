    public function hm_list_store(TodoRequest $request)
    {//-- TODOリスト登録
        //
        $maxRecId = TodoList::max('rec_id');
        $nextRecId = $maxRecId + 1;
        $todo_savedata = [
            'rec_id'      => $nextRecId,
            'cat_id'      => $request->cat_id,
            'mission'     => $request->todo_mission,
            'flg_fin'     => 0,
            'fin_until'   => $request->fin_until,
            'rep_user_id' => Auth::id(),
        ];

        $db_data = new TodoList;
        $db_data->fill($todo_savedata)->save();

        return redirect('/hm_todo/list')->with('poststatus', '新規登録しました');

    }

    public function hm_list_update(Request $request)
    {//-- TODOリスト更新

        //-- TODOリストの更新 --
        //---- 連想配列作成 ---
        $todos=array();
        $todos_rec_id=0;
        $todos_cat_id=0;
        $todos_mission="";
        $todos_flg_fin=0;
        $todos_fin_until="";
        $todos_rep_user_id=0;
        $counter=0;

        foreach ($request->all() as $key => $val){
            echo "<div>".$key."=>".$val."</div><br>";

            if(strpos($key,'todo_rec_id') !== false){ 
              //キーがID（rec_id）だった場合
              $todos_rec_id = $val;
            }
            if(strpos($key,'todo_cat_id') !== false){ 
              //キーがカテゴリID（cat_id）だった場合
              $todos_cat_id = $val;
            }
            if(strpos($key,'todo_mission') !== false){ 
              //キーがTODO内容（mission）だった場合
              $todos_mission = $val;
            }
            if(strpos($key,'todo_flg_fin') !== false){ 
              //キーが完了チェック（flg_fin）だった場合(値はonでしか来ない)
              $todos_flg_fin = 1;
            }
            if(strpos($key,'todo_fin_until') !== false){ 
              //キーがTODO期日（fin_until）だった場合
              $todos_fin_until = $val;
            }
            if(strpos($key,'todo_user_id') !== false){ 
              //キーが登録者ID（rep_user_id）だった場合
              $todos_rep_user_id = $val;
            }

            if(strpos($key,'todo_br') !== false){ 
              //キーが項目終了（br）だった場合
              $todos[$counter] = array('rec_id'      => $todos_rec_id, 
                                       'cat_id'      => $todos_cat_id, 
                                       'mission'     => $todos_mission,
                                       'flg_fin'     => $todos_flg_fin,
                                       'fin_until'   => $todos_fin_until,
                                       'rep_user_id' => $todos_rep_user_id);
              $counter++;
              $todos_rec_id=0;
              $todos_cat_id=0;
              $todos_mission="";
              $todos_flg_fin=0;
              $todos_fin_until="";
              $todos_rep_user_id=0;
              echo "-------<br>";
            }
        }
        //var_dump($todos);

        //-- 編集前のTODOデータ削除
        TodoList::query()->delete();

        //-- 今回編集データを新たに挿入
        foreach ($todos as $todo){
            $todo_savedata = [
                'rec_id'      => $todo["rec_id"],
                'cat_id'      => $todo["cat_id"],
                'mission'      => $todo["mission"],
                'flg_fin'      => $todo["flg_fin"],
                'fin_until'      => $todo["fin_until"],
                'rep_user_id'      => $todo["rep_user_id"],
            ];

            $db_data = new TodoList;
            $db_data->fill($todo_savedata)->save();

            print_r($todo_savedata);
            echo "<br>";
        }

        return redirect('/hm_todo/list')->with('poststatus', 'リスト更新しました');

    }


