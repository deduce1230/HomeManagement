    public function tweet_store(TweetRequest $request)
    {//-- 一言日記保存処理
        //
        $maxRecId = Tweet::max('rec_id');
        $nextRecId = $maxRecId + 1;
        $tweet_savedata = [
            'rec_id'      => $nextRecId,
            'tweet_date'  => $request->tweet_date,
            'tweet'       => $request->tweet,
            'ref_url'     => $request->ref_url,
            'rep_user_id' => Auth::id(),
        ];

        $db_data = new Tweet;
        $db_data->fill($tweet_savedata)->save();

        // 画像保存
        //if (!is_null($request->imagedata)){
        if (strlen($request->imagedata) > 3000){//何もcanvasになくてもちょっと送られてくるみたいなので・・・
            $image = $request->imagedata;  // your base64 encoded
            $image = str_replace('data:image/jpeg;base64,', '', $image);
            $image = str_replace('data:image/png;base64,', '', $image);
            $image = str_replace(' ', '+', $image);

            $imageName = 'diary'.$nextRecId.'.jpg';
            \File::put(public_path(). '/photos/diary/' . $imageName, base64_decode($image));
        }

        //return redirect('/hm_twitter/tweet')->with('poststatus', '新規登録しました');
        return redirect('/')->with('poststatus', '新規登録しました');

    }
